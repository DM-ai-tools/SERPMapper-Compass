# =============================================================================
# SERPMapper — environment variables (copy to .env.local and fill in values)
# Next.js loads: .env, .env.local, .env.[mode].local  (see Next.js env docs)
# Never commit .env.local — it is listed in .gitignore.
# =============================================================================

# ─── PostgreSQL (required for the app + scripts) ───────────────
# This project uses the `pg` driver (src/lib/db.ts), not the Supabase JS client.
#
# Local Windows / macOS / Linux (replace YOUR_USER, YOUR_PASSWORD, and DB name):
#  1) Start the PostgreSQL service.
#  2) Create an empty database, e.g. in psql or pgAdmin:
#        CREATE DATABASE serpmapper;
#  3) Set DATABASE_URL. Prefer 127.0.0.1 over "localhost" if you see ECONNREFUSED
#     (avoids some IPv4/IPv6 issues).
#  4) Apply all tables:  npm run db:setup
#     (or start the app once: ensureDatabaseReady() runs the same SQL on first use.)
#
# If your password has @ # % etc., URL-encode it in the connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@127.0.0.1:5432/serpmapper

# Optional — only if you use legacy seed-search-volumes script / old docs:
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# ─── DataforSEO (required) ───────────────────────────────────
# API base used in code: https://api.dataforseo.com/v3
DATAFORSEO_LOGIN=your-login@email.com
DATAFORSEO_PASSWORD=your-api-password

# ─── Google Places API (New) (required) ─────────────────────
# Enable "Places API (New)" in Google Cloud Console.
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# ─── Anthropic (required for AI copy in /api/analyze) ────────
ANTHROPIC_API_KEY=your-anthropic-api-key
# Optional model overrides (src/lib/claude.ts)
# ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_MODEL_FALLBACK=claude-haiku-4-5-20251001

# ─── SendGrid (optional but recommended for lead emails) ───
# API key must start with SG. for /api/lead to send email.
SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDGRID_FROM_EMAIL=hello@serpmap.com.au
# Legacy: nurture templates are not used by current inline HTML in sendgrid.ts
# SENDGRID_TEMPLATE_CONFIRMATION=d-your-template-id
# SENDGRID_TEMPLATE_DAY3=d-your-template-id
# SENDGRID_TEMPLATE_DAY7=d-your-template-id

# ─── Lead URLs ───────────────────────────────────────────────
# Server email CTA (buildLeadCtaUrl in src/lib/sendgrid.ts)
LEAD_CTA_BASE_URL=https://trafficradius.com.au/contact-us/
# Client: header FREE AUDIT, home + report “book a call” use this URL in code (src/lib/lead-cta.ts).
# NEXT_PUBLIC_LEAD_CTA_BASE_URL is not read for those buttons (avoids accidental wrong redirects).

# ─── Webhook ─────────────────────────────────────────────────
# Header: x-webhook-secret  →  must match  WEBHOOK_SECRET
# Used by: POST /api/webhooks/conversion
WEBHOOK_SECRET=generate-a-random-32-char-secret-here
# RANKPILOT webhook: POST /api/webhooks/rankpilot  → 410 (removed)

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
DAILY_REPORT_QUOTA=200

# Optional: protect UI with /login (see middleware.ts; APIs stay open)
# LOGIN_USERNAME=trafficradius
# LOGIN_PASSWORD=set-a-strong-password

# Optional — scripts only
# ANALYZE_BASE_URL=http://localhost:3000
# NOMINATIM_CONTACT_EMAIL=you@example.com
# LIMIT=100
